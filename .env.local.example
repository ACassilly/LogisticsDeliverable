# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/portlandia_logistics

# JWT
JWT_SECRET=change-me-in-production-use-32-char-min
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Odoo
ODOO_URL=https://your-instance.odoo.com
ODOO_DB=your-db
ODOO_USERNAME=admin
ODOO_PASSWORD=your-password

# Email (nodemailer)
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@portlandialogistics.com

# GTZShip
GTZSHIP_API_URL=https://api.gtzship.com
GTZSHIP_API_KEY=

# Public
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
