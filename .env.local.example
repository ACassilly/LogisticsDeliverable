# ─────────────────────────────────────────
# PES Global Group LLC — Portlandia Logistics
# Environment Variables Reference
# Copy to .env.local and fill in real values
# ─────────────────────────────────────────

# ── Database ─────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/portlandia_logistics

# ── Auth ─────────────────────────────────
JWT_SECRET=replace-with-64-char-random-secret
JWT_EXPIRES_IN=2d

# ── Admin seed ───────────────────────────
ADMIN_EMAIL=admin@portlandialogistics.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Platform Admin

# ── Cloudinary ───────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Stripe ───────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── GTZShip / GlobalTranz Rate API ───────
GTZSHIP_API_URL=https://dev.gtzintegrate.com/rate/ltl/partner
GTZSHIP_ACCESS_KEY=
GTZSHIP_USERNAME=
GTZSHIP_PASSWORD=
GTZSHIP_CUSTOMER_ID=

# ── Odoo XML-RPC ─────────────────────────
ODOO_URL=https://your-odoo-instance.odoo.com
ODOO_DB=your_database_name
ODOO_USERNAME=api@yourodoo.com
ODOO_PASSWORD=

# ── Email (Nodemailer / SMTP) ─────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@portlandialogistics.com
SMTP_PASS=
SMTP_FROM=Portlandia Logistics <noreply@portlandialogistics.com>

# ── App URL ───────────────────────────────
NEXT_PUBLIC_APP_URL=https://portlandialogistics.com
